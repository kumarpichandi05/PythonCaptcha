import os
import cv2
import numpy as np
import json
import re
import tempfile
import traceback
from paddleocr import PaddleOCR

def log(message):
    print(f"[LOG] {message}")  # For Blue Prism console logging

def get_script_directory():
    return os.path.dirname(os.path.abspath(__file__))

def get_image_files(folder_path, extensions):
    return [f for f in os.listdir(folder_path) if os.path.splitext(f)[1].lower() in extensions]

def read_image(image_path):
    if not os.path.exists(image_path):
        log(f"File not found: {image_path}")
        return None
    image = cv2.imread(image_path)
    if image is None:
        log(f"OpenCV failed to read: {image_path}")
    return image

def sanitize_filename(name):
    # Remove invalid filename characters
    return re.sub(r'[\\/*?:"<>|]', "_", name)

def remove_isolated_pixels(binary_image):
    h, w = binary_image.shape
    cleaned_image = binary_image.copy()
    for i in range(1, h - 1):
        for j in range(1, w - 1):
            neighborhood = binary_image[i-1:i+2, j-1:j+2]
            if binary_image[i, j] == 255 and np.sum(neighborhood) <= 255:
                cleaned_image[i, j] = 0
    return cleaned_image

def preprocess_image(image):
    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
    denoised = cv2.fastNlMeansDenoising(gray, h=10, templateWindowSize=4, searchWindowSize=21)
    _, binary = cv2.threshold(denoised, 128, 255, cv2.THRESH_BINARY_INV)
    cleaned = remove_isolated_pixels(binary)
    kernel = np.ones((3, 3), np.uint8)
    closed = cv2.morphologyEx(cleaned, cv2.MORPH_CLOSE, kernel)
    return closed

def save_temp_image(image, suffix=".png"):
    temp_file = tempfile.NamedTemporaryFile(suffix=suffix, delete=False)
    cv2.imwrite(temp_file.name, image)
    return temp_file.name

def extract_text(image_array, ocr_model):
    try:
        result = ocr_model.ocr(image_array, det=False)
        if isinstance(result, list) and result and isinstance(result[0], list) and result[0] and isinstance(result[0][0], tuple):
            return result[0][0][0].replace(" ", "")
        return "no_text_detected"
    except Exception as e:
        log(f"OCR failed: {e}")
        return "ocr_error"

def save_to_json(data, filename):
    try:
        with open(filename, 'w') as f:
            json.dump(data, f, indent=4)
        log(f"Saved to JSON: {filename}")
    except Exception as e:
        log(f"Failed to save JSON: {e}")

def limit_image_size(image, max_dim=2000):
    h, w = image.shape[:2]
    if h > max_dim or w > max_dim:
        scaling_factor = max_dim / max(h, w)
        image = cv2.resize(image, (int(w * scaling_factor), int(h * scaling_factor)))
        log(f"Image resized to {image.shape[1]}x{image.shape[0]}")
    return image

def main():
    try:
        ocr = PaddleOCR()
        script_dir = get_script_directory()
        folder_path = os.path.join(script_dir, "Inp_images")
        image_extensions = {".png", ".jpg", ".jpeg", ".bmp", ".tiff"}

        if not os.path.exists(folder_path):
            log(f"Image folder not found: {folder_path}")
            return

        image_files = get_image_files(folder_path, image_extensions)
        if not image_files:
            log("No image files found.")
            return

        for image_file in image_files:
            try:
                image_path = os.path.join(folder_path, image_file)
                log(f"Processing image: {image_path}")
                image = read_image(image_path)
                if image is None:
                    continue

                image = limit_image_size(image)

                processed_image = preprocess_image(image)
                temp_image_path = save_temp_image(processed_image)

                text = extract_text(temp_image_path, ocr)

                safe_text = sanitize_filename(text)
                json_filename = os.path.join(script_dir, f"{safe_text}.json")
                save_to_json(text, json_filename)

                os.unlink(temp_image_path)  # Delete temp image after use
                log(f"Completed processing for: {image_file}")

            except Exception as e_inner:
                log(f"Error processing {image_file}: {traceback.format_exc()}")

    except Exception as e_outer:
        log(f"Fatal error: {traceback.format_exc()}")

if __name__ == "__main__":
    main()