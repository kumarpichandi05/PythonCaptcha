using System;
using Tesseract;

class Program
{
    static void Main()
    {
        // Path to the Tesseract language data
        string tessdataPath = @"C:\path\to\tessdata";  // Update with the actual path to tessdata folder

        // Path to the image you want to process
        string imagePath = @"C:\path\to\image.png"; // Update with the actual image file path

        try
        {
            // Initialize Tesseract engine with both English and Arabic languages
            using (var engine = new TesseractEngine(tessdataPath, "eng+ara", EngineMode.Default))
            {
                // Load the image
                using (var img = Pix.LoadFromFile(imagePath))
                {
                    // Perform OCR on the image
                    using (var page = engine.Process(img))
                    {
                        // Extract the text
                        string text = page.GetText();
                        Console.WriteLine("Extracted Text: ");
                        Console.WriteLine(text);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}