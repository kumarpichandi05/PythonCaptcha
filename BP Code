        var headers = new[] { "US\\$", "GBP", "EURIBOR", "CAS", "€STER", "KIBOR", "EBOR" };
        var results = new List<Dictionary<string, object>>();

        foreach (var header in headers)
        {
            var pattern = $@"{header}\s*(.*?)(?=(US\$|GBP|EURIBOR|CAS|€STER|KIBOR|EBOR|\Z))";
            var match = Regex.Match(input, pattern, RegexOptions.Singleline);

            if (match.Success)
            {
                var block = match.Groups[1].Value;
                var numberPattern = @"([A-Z\-\/]+)?\s*([-+]?\d+\.\d+)";
                var blockData = new List<Dictionary<string, object>>();

                foreach (Match numberMatch in Regex.Matches(block, numberPattern))
                {
                    var label = string.IsNullOrWhiteSpace(numberMatch.Groups[1].Value) ? null : numberMatch.Groups[1].Value;
                    var value = decimal.Parse(numberMatch.Groups[2].Value, CultureInfo.InvariantCulture);

                    blockData.Add(new Dictionary<string, object>
                    {
                        ["Label"] = label,
                        ["Value"] = value
                    });
                }

                results.Add(new Dictionary<string, object>
                {
                    ["Header"] = header.Replace("\\", ""),
                    ["Data"] = blockData
                });
            }
        }

        string json = JsonSerializer.Serialize(results, new JsonSerializerOptions { WriteIndented = true });
        File.WriteAllText("structured_interest_rates.json", json);
        Console.WriteLine("Saved to structured_interest_rates.json");
    }
